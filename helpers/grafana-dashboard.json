{
  "apiVersion": "dashboard.grafana.app/v2beta1",
  "kind": "DashboardWithAccessInfo",
  "metadata": {
    "annotations": {}
  },
  "spec": {
    "annotations": [
      {
        "kind": "AnnotationQuery",
        "spec": {
          "builtIn": true,
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "query": {
            "group": "grafana",
            "kind": "DataQuery",
            "spec": {},
            "version": "v0"
          }
        }
      }
    ],
    "cursorSync": "Off",
    "editable": true,
    "elements": {
      "panel-10": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "exemplar": false,
                        "expr": "mtr_report_avg{dst=~\"$varDestination\", hop=\"last\"}\n* on(dst) # get rid of all labels but \"dst\"\ngroup_right() group by(dst) (mtr_report_avg{dst=~\"$varDestination\", hop=\"last\"})",
                        "format": "time_series",
                        "instant": false,
                        "legendFormat": "__auto",
                        "range": true
                      },
                      "version": "v0"
                    },
                    "refId": "avgRtt"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "exemplar": false,
                        "expr": "mtr_report_min_loss{dst=~\"$varDestination\", hop=\"last\"}\n* on(dst) # get rid of all labels but \"dst\"\ngroup_right() group by(dst) (mtr_report_min_loss{dst=~\"$varDestination\", hop=\"last\"})",
                        "format": "time_series",
                        "instant": false,
                        "legendFormat": "__auto",
                        "range": true
                      },
                      "version": "v0"
                    },
                    "refId": "minLoss"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "expr": "changes((mtr_report_path_id{dst=~\"$varDestination\", hop=\"last\"}\n  * on(dst) # get rid of all labels but \"dst\"\n  group_right group by(dst) (mtr_report_path_id{dst=~\"$varDestination\", hop=\"last\"}))[$__interval:1m])\n\n+\n\nchanges((mtr_report_count_hubs{dst=~\"$varDestination\", hop=\"last\"}\n  * on(dst) # get rid of all labels but \"dst\"\n  group_right() group by(dst) (mtr_report_count_hubs{dst=~\"$varDestination\", hop=\"last\"}))[$__interval:1m])\n",
                        "instant": false,
                        "legendFormat": "__auto",
                        "range": true
                      },
                      "version": "v0"
                    },
                    "refId": "pathID"
                  }
                }
              ],
              "queryOptions": {
                "interval": "5m"
              },
              "transformations": []
            }
          },
          "description": "Shows measured average RTT on left axis, minimum measured packet loss on the right axis and the detected path changes along the router in the center",
          "id": 10,
          "links": [],
          "title": "Average RTT, Packet Loss & Path Changes",
          "vizConfig": {
            "group": "timeseries",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "palette-classic-by-name"
                  },
                  "custom": {
                    "axisBorderShow": false,
                    "axisCenteredZero": false,
                    "axisColorMode": "text",
                    "axisLabel": "",
                    "axisPlacement": "auto",
                    "barAlignment": 0,
                    "barWidthFactor": 0.6,
                    "drawStyle": "line",
                    "fillOpacity": 0,
                    "gradientMode": "none",
                    "hideFrom": {
                      "legend": false,
                      "tooltip": false,
                      "viz": false
                    },
                    "insertNulls": false,
                    "lineInterpolation": "linear",
                    "lineWidth": 1,
                    "pointSize": 5,
                    "scaleDistribution": {
                      "type": "linear"
                    },
                    "showPoints": "auto",
                    "showValues": false,
                    "spanNulls": false,
                    "stacking": {
                      "group": "A",
                      "mode": "none"
                    },
                    "thresholdsStyle": {
                      "mode": "off"
                    }
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": 0
                      }
                    ]
                  }
                },
                "overrides": [
                  {
                    "matcher": {
                      "id": "byFrameRefID",
                      "options": "avgRtt"
                    },
                    "properties": [
                      {
                        "id": "custom.axisPlacement",
                        "value": "left"
                      },
                      {
                        "id": "custom.axisLabel",
                        "value": "RTT (ms)"
                      },
                      {
                        "id": "unit",
                        "value": "ms"
                      },
                      {
                        "id": "min",
                        "value": 0
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byFrameRefID",
                      "options": "minLoss"
                    },
                    "properties": [
                      {
                        "id": "custom.drawStyle",
                        "value": "bars"
                      },
                      {
                        "id": "custom.barWidthFactor",
                        "value": 0.9
                      },
                      {
                        "id": "custom.axisLabel",
                        "value": "Minimum Loss (%)"
                      },
                      {
                        "id": "unit",
                        "value": "percent"
                      },
                      {
                        "id": "custom.axisPlacement",
                        "value": "right"
                      },
                      {
                        "id": "custom.fillOpacity",
                        "value": 100
                      },
                      {
                        "id": "custom.hideFrom",
                        "value": {
                          "legend": true,
                          "tooltip": true,
                          "viz": false
                        }
                      },
                      {
                        "id": "custom.axisSoftMax",
                        "value": 105
                      },
                      {
                        "id": "custom.axisSoftMin",
                        "value": 0
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byFrameRefID",
                      "options": "pathID"
                    },
                    "properties": [
                      {
                        "id": "custom.axisPlacement",
                        "value": "left"
                      },
                      {
                        "id": "decimals",
                        "value": 0
                      },
                      {
                        "id": "custom.drawStyle",
                        "value": "bars"
                      },
                      {
                        "id": "custom.fillOpacity",
                        "value": 33
                      },
                      {
                        "id": "custom.barAlignment",
                        "value": 0
                      },
                      {
                        "id": "custom.barWidthFactor",
                        "value": 0.5
                      },
                      {
                        "id": "custom.hideFrom",
                        "value": {
                          "legend": true,
                          "tooltip": true,
                          "viz": false
                        }
                      },
                      {
                        "id": "custom.axisPlacement",
                        "value": "hidden"
                      },
                      {
                        "id": "custom.axisCenteredZero",
                        "value": true
                      },
                      {
                        "id": "custom.transform",
                        "value": "negative-Y"
                      }
                    ]
                  }
                ]
              },
              "options": {
                "legend": {
                  "calcs": [
                    "lastNotNull",
                    "max",
                    "min"
                  ],
                  "displayMode": "table",
                  "placement": "right",
                  "showLegend": true
                },
                "timezone": [
                  "utc"
                ],
                "tooltip": {
                  "hideZeros": false,
                  "mode": "multi",
                  "sort": "none"
                }
              }
            },
            "version": "12.3.1"
          }
        }
      },
      "panel-4": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "expr": "max by (dst, count, path_id) (last_over_time(mtr_report_loss{hop=\"last\", dst=~\"$varDestination\"}[1m]))",
                        "format": "table",
                        "legendFormat": "__auto",
                        "range": true
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": [
                {
                  "kind": "organize",
                  "spec": {
                    "id": "organize",
                    "options": {
                      "excludeByName": {},
                      "includeByName": {},
                      "indexByName": {
                        "Time": 0,
                        "Value": 4,
                        "count": 3,
                        "dst": 1,
                        "path_id": 2
                      },
                      "renameByName": {
                        "Value": "Loss %",
                        "count": "Number Hops",
                        "dst": "Destination",
                        "path_id": "Path ID"
                      }
                    }
                  }
                }
              ]
            }
          },
          "description": "",
          "id": 4,
          "links": [],
          "title": "",
          "vizConfig": {
            "group": "table",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "continuous-GrYlRd"
                  },
                  "custom": {
                    "align": "auto",
                    "cellOptions": {
                      "type": "auto"
                    },
                    "filterable": true,
                    "footer": {
                      "reducers": []
                    },
                    "inspect": false
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": 0
                      }
                    ]
                  }
                },
                "overrides": []
              },
              "options": {
                "cellHeight": "sm",
                "enablePagination": true,
                "showHeader": true,
                "sortBy": [
                  {
                    "desc": true,
                    "displayName": "Time"
                  }
                ]
              }
            },
            "version": "12.3.1"
          }
        }
      }
    },
    "layout": {
      "kind": "RowsLayout",
      "spec": {
        "rows": [
          {
            "kind": "RowsLayoutRow",
            "spec": {
              "collapse": false,
              "layout": {
                "kind": "GridLayout",
                "spec": {
                  "items": [
                    {
                      "kind": "GridLayoutItem",
                      "spec": {
                        "element": {
                          "kind": "ElementReference",
                          "name": "panel-10"
                        },
                        "height": 9,
                        "width": 24,
                        "x": 0,
                        "y": 0
                      }
                    }
                  ]
                }
              },
              "title": "MTR Measurements"
            }
          },
          {
            "kind": "RowsLayoutRow",
            "spec": {
              "collapse": false,
              "layout": {
                "kind": "GridLayout",
                "spec": {
                  "items": [
                    {
                      "kind": "GridLayoutItem",
                      "spec": {
                        "element": {
                          "kind": "ElementReference",
                          "name": "panel-4"
                        },
                        "height": 10,
                        "width": 24,
                        "x": 0,
                        "y": 0
                      }
                    }
                  ]
                }
              },
              "title": "Details"
            }
          }
        ]
      }
    },
    "links": [],
    "liveNow": false,
    "preload": false,
    "tags": [
      "network",
      "mtr"
    ],
    "timeSettings": {
      "autoRefresh": "",
      "autoRefreshIntervals": [
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "2h",
        "1d"
      ],
      "fiscalYearStartMonth": 0,
      "from": "now-1h",
      "hideTimepicker": false,
      "timezone": "utc",
      "to": "now"
    },
    "title": "MTR Exporter",
    "variables": [
      {
        "kind": "QueryVariable",
        "spec": {
          "allowCustomValue": true,
          "current": {
            "text": "",
            "value": ""
          },
          "definition": "label_values(mtr_report_loss,dst)",
          "hide": "dontHide",
          "includeAll": true,
          "label": "Destination",
          "multi": true,
          "name": "varDestination",
          "options": [],
          "query": {
            "group": "prometheus",
            "kind": "DataQuery",
            "spec": {
              "qryType": 1,
              "query": "label_values(mtr_report_loss,dst)",
              "refId": "PrometheusVariableQueryEditor-VariableQuery"
            },
            "version": "v0"
          },
          "refresh": "onTimeRangeChanged",
          "regex": "",
          "regexApplyTo": "value",
          "skipUrlSync": false,
          "sort": "alphabeticalAsc"
        }
      },
      {
        "kind": "QueryVariable",
        "spec": {
          "allowCustomValue": true,
          "current": {
            "text": "",
            "value": ""
          },
          "definition": "label_values(mtr_report_loss{dst=~\"$varDestination\"},path_id)",
          "hide": "dontHide",
          "includeAll": true,
          "label": "Path ID",
          "multi": true,
          "name": "varPathId",
          "options": [],
          "query": {
            "group": "prometheus",
            "kind": "DataQuery",
            "spec": {
              "qryType": 1,
              "query": "label_values(mtr_report_loss{dst=~\"$varDestination\"},path_id)",
              "refId": "PrometheusVariableQueryEditor-VariableQuery"
            },
            "version": "v0"
          },
          "refresh": "onTimeRangeChanged",
          "regex": "",
          "regexApplyTo": "value",
          "skipUrlSync": false,
          "sort": "disabled"
        }
      }
    ]
  },
  "status": {}
}
